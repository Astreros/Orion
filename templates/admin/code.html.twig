{% extends 'base.html.twig' %}

{% block title %}Administration Code PIN{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #38D5BE; padding: 2px 6px; }
    </style>

    <div class="example-wrapper">
        <h1>Administration des Code PIN</h1>

        {% if app.user %}
            <a href="{{ path('app_logout') }}">Déconnexion</a>
        {% endif %}

        <br>
        <br>

        <a href="{{ path('show.admin') }}">Retour Accueil Administration</a>

        <div class="container mt-4">
            <h1>Liste des Code PIN</h1>

        </div>
    </div>
{% endblock %}